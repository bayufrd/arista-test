@model IEnumerable<AristaEmployeeApp.Models.Karyawan>

@{
    ViewData["Title"] = "Daftar Karyawan";
}

<h1>Daftar Karyawan</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Tambah Karyawan</a>
</p>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<table class="table">
    <thead>
        <tr>
            <th>Kode</th>
            <th>Nama</th>
            <th>Perusahaan</th>
            <th>Cabang</th>
            <th>Aksi</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr id="row-@item.Id">
            <td>@item.KodeKaryawan</td>
            <td>@item.Nama</td>
            <td>@(item.Cabang?.Perusahaan?.Nama ?? "-")</td>
            <td>@(item.Cabang?.Nama ?? "-")</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Edit</a>
                <button onclick="deleteKaryawan(@item.Id)" class="btn btn-sm btn-danger">Delete</button>
            </td>
        </tr>
}
    </tbody>
</table>

@section Scripts {
    <script>
        function deleteKaryawan(id) {
            if (confirm('Yakin ingin menghapus data ini?')) {
                $.post('/Karyawan/Delete/' + id, function (data) {
                    if (data.success) {
                        $('#row-' + id).remove();
                        alert('Berhasil dihapus');
                    } else {
                        alert('Gagal menghapus');
                    }
                });
            }
        }
    </script>
}
